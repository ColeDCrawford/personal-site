---
import { TECH } from "~/lib/tech";

interface Props {
  tech: string;
}
const { tech } = Astro.props;
const meta = TECH[tech];
const display = meta?.display ?? tech;
const file = meta?.file;
---

<span
  class="inline-flex items-center gap-2 rounded-full bg-ink-100/80 dark:bg-ink-700/40 px-3 py-1 text-xs font-medium"
  title={display}
>
  {
    file && (
      <img
        src={`/tech/${file}`}
        alt=""
        width="40"
        height="40"
        class="w-4 h-4 object-contain"
        loading="lazy"
      />
    )
  }
  {display}
</span>
