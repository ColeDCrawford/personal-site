---
import { getCollection } from "astro:content";
import Layout from "~/layouts/Layout.astro";
import ProjectCard from "~/components/ProjectCard.astro";

const all = await getCollection("projects");
const sorted = all.sort((a, b) => {
  const ya = a.data.start_date ?? "";
  const yb = b.data.start_date ?? "";
  return yb.localeCompare(ya);
});
---

<Layout
  title="Projects — Cole Crawford"
  description="A catalog of projects I've built, from digital archives to research tooling."
>
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-6">
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight">
      Projects
    </h1>
    <p class="mt-3 max-w-2xl text-ink-500">
      {sorted.length} projects spanning digital archives, visualization, NLP,
      and research infrastructure.
    </p>
  </section>
  <section class="mx-auto max-w-5xl px-6 py-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>
</Layout>
