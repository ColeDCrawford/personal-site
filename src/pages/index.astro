---
import { getCollection } from "astro:content";
import Layout from "~/layouts/Layout.astro";
import ProjectCard from "~/components/ProjectCard.astro";

const all = await getCollection("projects");
const sorted = all.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const featured = sorted.filter((p) => p.data.featured).slice(0, 6);
---

<Layout title="Cole Crawford">
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-10">
    <p class="text-sm uppercase tracking-widest text-accent-600 font-medium">
      Hi, I'm Cole
    </p>
    <h1
      class="mt-3 font-serif text-4xl sm:text-6xl font-semibold leading-tight tracking-tight"
    >
      Staff AI Engineer
      <span class="text-ink-500">
        shipping agents, LLM pipelines, and the systems around them.
      </span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-ink-500 leading-relaxed">
      I'm a Staff AI Engineer at Reify Health, previously Senior AI Engineer at
      Wood Mackenzie. Before transitioning to industry, I spent eight years
      building research software for the humanities at Harvard University's
      Arts and Humanities Research Computing group. I also run
      <a
        href="https://hapax.digital"
        class="underline decoration-accent-400/70 underline-offset-4 hover:text-accent-600 transition"
        >Hapax Digital</a
      >, an AI and software engineering consultancy focused on digital
      humanities and ed tech projects.
    </p>
    <div class="mt-8 flex items-center gap-4">
      <a
        href="/projects"
        class="inline-flex items-center rounded-full bg-accent-600 text-ink-50 px-5 py-2.5 text-sm font-medium hover:bg-accent-500 transition"
      >
        See projects →
      </a>
      <a
        href="mailto:cole@hapax.digital"
        class="text-sm font-medium text-ink-500 hover:text-accent-600 transition"
      >
        Get in touch
      </a>
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="mx-auto max-w-5xl px-6 py-10">
        <div class="flex items-end justify-between mb-6">
          <h2 class="font-serif text-2xl font-semibold">Featured work</h2>
          <a
            href="/projects"
            class="text-sm font-medium text-ink-500 hover:text-accent-600 transition"
          >
            All projects →
          </a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((p, i) => (
            <div class:list={[i === 0 && "sm:col-span-2 lg:col-span-2"]}>
              <ProjectCard project={p} featured={i === 0} />
            </div>
          ))}
        </div>
      </section>
    )
  }
</Layout>
