---
import Layout from "~/layouts/Layout.astro";

const experience = [
  {
    title: "Staff AI Engineer",
    org: "Reify Health",
    dates: "2026 – Present",
    blurb:
      "Applied AI for managing clinical trials.",
  },
  {
    title: "Senior AI Software Engineer",
    org: "Wood Mackenzie · Core AI Platform",
    dates: "Apr 2025 – Apr 2026",
    blurb:
      "First hire on the newly-formed Core AI Platform team. Led the ground-up redesign of Woody — Woodmac's internal chatbot and agentic AI framework — and built Quarry, a document-processing and retrieval system that unified search across the firm's content.",
  },
  {
    title: "Senior Software Engineer",
    org: "Harvard — Arts & Humanities Research Computing",
    dates: "Jul 2023 – Apr 2025",
    blurb:
      "Technical lead for the DARTH engineering team. Mentored engineers, led multiple full stack projects from inception to sunsetting, planned long-term digital scholarship strategy with the Library and HUIT, and served on the steering committee of the DHTech ADHO Special Interest Group.",
  },
  {
    title: "Software Engineer",
    org: "Harvard — Arts & Humanities Research Computing",
    dates: "Mar 2021 – Jul 2023",
    blurb:
      "Built custom web applications, text-analysis pipelines, data models, and visualizations for FAS faculty. Maintained the group's AWS infrastructure (ECS Fargate) and GitHub org. Co-chaired the Digital Scholarship Support Group and launched a Digital Scholarship Graduate Certificate.",
  },
  {
    title: "Humanities Research Computing Specialist",
    org: "Harvard — Arts & Humanities Research Computing",
    dates: "Aug 2017 – Mar 2021",
    blurb:
      "Consulted on FAS digital projects end-to-end, connected faculty with Harvard Library and HUIT resources, and led workshops on digital research methods, tools, and programming.",
  },
  {
    title: "Founder & Principal",
    org: "Hapax Digital",
    dates: "2026 – Present",
    blurb:
      "An AI and software-engineering consultancy focused on digital humanities and ed-tech projects. Current engagement: an agentic system for Jesuit formation at Saint Louis University.",
  },
];

const education = [
  {
    degree: "Master of Liberal Arts, Software Engineering",
    school: "Harvard Extension School",
    year: "2017 – 2023",
  },
  {
    degree: "M.A., English (Literature and Culture)",
    school: "Oregon State University",
    year: "2015 – 2017",
  },
  {
    degree:
      "B.S., Computer Science & Informatics; English (British Literature)",
    school: "Creighton University · Honors, summa cum laude",
    year: "2011 – 2015",
  },
];

const publications = [
  {
    title: "DH Inside Out",
    venue: "",
  },
  {
    title: "Undate: Humanistic Dates for Computation",
    venue: "",
  },
  {
    title:
      "Exploring Big and Boutique Data through Laboring-Class Poets Online",
    venue: "",
  },
  {
    title:
      "Connecting Art and Science for Humanities Research: Mapping Color in History",
    venue: "",
  },
  {
    title:
      "Transforming Working Class Writers and Writing",
    venue: "in A History of British Working Class Literature, Cambridge UP",
  },
];
---

<Layout
  title="About — Cole Crawford"
  description="Cole Crawford — Staff AI Engineer at Reify Health, consultant at Hapax Digital, and former Harvard research software engineer."
>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-10">
    <h1 class="font-serif text-4xl sm:text-5xl font-semibold tracking-tight">
      About
    </h1>

    <div class="mt-8 space-y-5 text-lg text-ink-700 dark:text-ink-100 leading-relaxed">
      <p>
        I'm Cole, a software engineer focused on building GenAI systems for
        the web. I work primarily on the backend these days, with deep
        experience across frontend, DevOps, NLP, data visualization, and
        project management from years of shipping production systems for
        research.
      </p>
      <p>
        I'm currently a Staff AI Engineer at <strong>Reify Health</strong>,
        working on applied AI for managing clinical trials. Before Reify I
        was a Senior AI Software Engineer at <strong>Wood Mackenzie</strong>,
        the first hire on their new Core AI Platform team — leading the
        redesign of Woody, their internal agentic framework. Before industry I
        spent eight years at <strong>Harvard</strong>'s Arts & Humanities
        Research Computing group (DARTH), building roughly twenty research
        platforms — digital archives, TEI editing, IIIF image delivery,
        NLP-driven search, and a lot of data visualization.
      </p>
      <p>
        On the side I run <a
          href="https://hapax.digital"
          class="underline decoration-accent-400/70 underline-offset-4 hover:text-accent-600"
          >Hapax Digital</a
        >, an AI and software-engineering consultancy focused on digital
        humanities and ed-tech. Based in Somerville, MA.
      </p>
    </div>

    <section class="mt-14">
      <h2 class="font-serif text-2xl font-semibold mb-6">Experience</h2>
      <ol class="space-y-6 relative border-l border-ink-100 dark:border-ink-700/50 pl-6">
        {
          experience.map((r) => (
            <li class="relative">
              <span class="absolute -left-8.25 top-2 w-2.5 h-2.5 rounded-full bg-accent-500" />
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h3 class="font-semibold">
                  {r.title}
                  <span class="text-ink-500 font-normal"> · {r.org}</span>
                </h3>
                <span class="text-sm text-ink-500">{r.dates}</span>
              </div>
              <p class="mt-1 text-ink-500">{r.blurb}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="mt-14">
      <h2 class="font-serif text-2xl font-semibold mb-6">Education</h2>
      <ul class="space-y-3">
        {
          education.map((e) => (
            <li class="flex flex-wrap items-baseline justify-between gap-2">
              <div>
                <div class="font-medium">{e.degree}</div>
                <div class="text-ink-500">{e.school}</div>
              </div>
              <span class="text-sm text-ink-500 shrink-0">{e.year}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14">
      <h2 class="font-serif text-2xl font-semibold mb-6">
        Selected publications
      </h2>
      <ul class="space-y-3">
        {
          publications.map((p) => (
            <li>
              <div class="font-medium">{p.title}</div>
              {p.venue && <div class="text-ink-500 text-sm">{p.venue}</div>}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14 border-t border-ink-100 dark:border-ink-700/50 pt-8">
      <h2 class="font-serif text-2xl font-semibold mb-4">Get in touch</h2>
      <p class="text-ink-500">
        Email <a
          class="underline decoration-accent-400/70 underline-offset-4 hover:text-accent-600"
          href="mailto:cole@hapax.digital">cole@hapax.digital</a
        >, or find me on <a
          class="underline decoration-accent-400/70 underline-offset-4 hover:text-accent-600"
          href="https://github.com/ColeDCrawford">GitHub</a
        > and <a
          class="underline decoration-accent-400/70 underline-offset-4 hover:text-accent-600"
          href="https://www.linkedin.com/in/coledcrawford/">LinkedIn</a
        >.
      </p>
    </section>
  </section>
</Layout>
